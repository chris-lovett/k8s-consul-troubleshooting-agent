# Include main documentation files
include README.md
include LICENSE
include PROJECT_SUMMARY.md

# Include configuration files
include requirements.txt
include .env.example
recursive-include config *.yaml *.yml

# Include documentation directory
recursive-include docs *.md

# Include examples
recursive-include examples *.md *.hcl

# Include source package data
recursive-include src *.py

# Exclude test files and development artifacts
exclude test_*.py
exclude .gitignore
recursive-exclude tests *
recursive-exclude .venv *
recursive-exclude venv *
recursive-exclude __pycache__ *
recursive-exclude *.egg-info *
global-exclude *.pyc
global-exclude *.pyo
global-exclude .DS_Store
global-exclude *.pem